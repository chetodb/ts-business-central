{
  "name": "@chetodb/nestjs-business-central",
  "version": "0.1.2",
  "type": "module",
  "description": "NestJS module for seamless integration with Microsoft Dynamics 365 Business Central.",
  "license": "MIT",
  "author": "David Cheto (ChetoDB)",
  "homepage": "https://github.com/ChetoDB/ts-business-central/tree/main/packages/nestjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChetoDB/ts-business-central.git",
    "directory": "packages/nestjs"
  },
  "bugs": {
    "url": "https://github.com/ChetoDB/ts-business-central/issues"
  },
  "keywords": [
    "nestjs",
    "business-central",
    "dynamics",
    "typescript",
    "module",
    "sdk"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@chetodb/business-central": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
