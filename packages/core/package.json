{
  "name": "@chetodb/business-central",
  "version": "0.2.0",
  "type": "module",
  "description": "Modern, resilient and type-safe TypeScript SDK for Microsoft Dynamics 365 Business Central.",
  "license": "MIT",
  "author": "David Cheto (ChetoDB)",
  "homepage": "https://github.com/ChetoDB/ts-business-central/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChetoDB/ts-business-central.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ChetoDB/ts-business-central/issues"
  },
  "keywords": [
    "business-central",
    "dynamics",
    "sdk",
    "api",
    "typescript",
    "erp",
    "microsoft"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
