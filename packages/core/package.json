{
  "name": "@chetodb/business-central",
  "version": "0.0.0",
  "type": "module",
  "description": "Modern, resilient and type-safe TypeScript SDK for Microsoft Dynamics 365 Business Central.",
  "license": "MIT",
  "author": "David Cheto (ChetoDB)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
