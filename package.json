{
  "name": "ts-business-central",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "biome check .",
    "format": "biome check --write .",
    "playground": "tsx playground/index.ts",
    "playground:watch": "tsx watch playground/index.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
