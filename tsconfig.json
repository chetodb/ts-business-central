{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "@chetodb/business-central": ["./packages/core/src/index.ts"]
    }
  },
  "references": [{ "path": "./packages/core" }, { "path": "./packages/nestjs" }],
  "exclude": [
    "node_modules",
    "dist",
    "dumy-nestjs",
    "**/*.config.ts",
    "playground",
    "packages/**/test"
  ]
}
